# Copy this file to `.env` and fill in the values you actually want to use.
# `.env` is gitignored.

# Shared contract deployer key for both EVM and PVM Hardhat projects.
PRIVATE_KEY=0xYOUR_PASEO_PRIVATE_KEY

# Relayer signer for private withdraw on Paseo or any non-local network.
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY

# Optional RPC overrides.
ETH_RPC_HTTP=https://services.polkadothub-rpc.com/testnet
RELAYER_PORT=8787
RELAYER_QUOTE_TTL_SECONDS=600
RELAYER_QUOTE_GAS_UNITS=450000
RELAYER_PREMIUM_WEI=25000000000000
RELAYER_BUFFER_BPS=1500
