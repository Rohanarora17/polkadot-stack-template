# Copy this file to `.env` and fill in the values you actually want to use.
# `.env` is gitignored.

# Shared contract deployer key for both EVM and PVM Hardhat projects.
PRIVATE_KEY=0xYOUR_PASEO_PRIVATE_KEY

# Relayer signer for private withdraw on Paseo or any non-local network.
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY

# Optional app-managed Bulletin uploader.
# Authorize this Substrate account once on Bulletin, then normal users do not need
# their own Bulletin storage authorization for encrypted gift payload upload.
# BULLETIN_SIGNER_MNEMONIC="your twelve or twenty four word mnemonic"
# BULLETIN_SIGNER_PATH=
# BULLETIN_WS=wss://paseo-bulletin-rpc.polkadot.io
# BULLETIN_MAX_UPLOAD_BYTES=8388608
# BULLETIN_UPLOAD_RATE_WINDOW_MS=60000
# BULLETIN_UPLOAD_RATE_MAX=30
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,https://your-app.example

# Walletless-claim embedded H160 wallet provider.
# Privy is the primary claim-wallet provider. Walletless funds are withdrawn to
# the user's Privy embedded wallet; StealthPay never receives that private key.
VITE_PRIVY_APP_ID=

# Optional RPC overrides.
ETH_RPC_HTTP=https://services.polkadothub-rpc.com/testnet
RELAYER_PORT=8787
RELAYER_QUOTE_TTL_SECONDS=600
RELAYER_QUOTE_GAS_UNITS=450000
RELAYER_PREMIUM_WEI=25000000000000
RELAYER_BUFFER_BPS=1500

# Optional public event indexer beside the relayer.
STEALTHPAY_INDEXER_ENABLED=true
STEALTHPAY_INDEXER_WS=wss://asset-hub-paseo-rpc.n.dwellir.com
STEALTHPAY_INDEXER_LOOKBACK_BLOCKS=5000
STEALTHPAY_INDEXER_POLL_MS=6000
# STEALTHPAY_REGISTRY_ADDRESS=0x...
# STEALTHPAY_POOL_ADDRESS=0x...
