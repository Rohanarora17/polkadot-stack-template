# The app falls back to local endpoints on localhost and testnet endpoints elsewhere.
# Set these if you want explicit build-time defaults or script-driven local overrides.

# Preferred for local script-driven development:
# VITE_LOCAL_WS_URL=ws://127.0.0.1:10044
# VITE_LOCAL_ETH_RPC_URL=http://127.0.0.1:8645

VITE_LOCAL_WS_URL=ws://127.0.0.1:9944
VITE_LOCAL_ETH_RPC_URL=http://127.0.0.1:8545

VITE_WS_URL=ws://127.0.0.1:9944
VITE_ETH_RPC_URL=http://127.0.0.1:8545

# Example Polkadot Hub TestNet defaults:
# VITE_WS_URL=wss://asset-hub-paseo-rpc.n.dwellir.com
# VITE_ETH_RPC_URL=https://services.polkadothub-rpc.com/testnet

# Optional StealthPay public event indexer for exact gift lookup.
# Default local relayer/indexer URL is http://127.0.0.1:8787.
# Set VITE_STEALTHPAY_INDEXER_KIND=none to force direct RPC/runtime scanning.
# VITE_STEALTHPAY_INDEXER_URL=http://127.0.0.1:8787

# Optional Blockscout fallback for Paseo public logs.
# VITE_STEALTHPAY_INDEXER_KIND=blockscout
# VITE_STEALTHPAY_INDEXER_URL=https://blockscout-testnet.polkadot.io

# Walletless-claim embedded H160 wallet provider.
# Privy is the primary claim-wallet provider.
# VITE_PRIVY_APP_ID=
