{
	"name": "polkadot-stack-template-web",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=22 <23",
		"npm": ">=10"
	},
	"scripts": {
		"codegen": "papi generate",
		"update-types": "papi update",
		"dev": "vite",
		"dev:blockchain": "npm run update-types && vite",
		"zk:build": "node ./scripts/generate-private-withdraw-artifacts.mjs",
		"build": "npm run codegen && tsc -b && vite build",
		"postinstall": "npm run codegen",
		"lint": "eslint .",
		"test": "vitest run",
		"test:crypto": "vitest run src/crypto/*.test.ts",
		"test:e2e": "node ./e2e/run.mjs",
		"test:e2e:headed": "node ./e2e/run.mjs --headed",
		"fmt": "prettier --write 'src/**/*.{ts,tsx}'",
		"fmt:check": "prettier --check 'src/**/*.{ts,tsx}'",
		"preview": "vite preview"
	},
	"dependencies": {
		"@apillon/wallet-sdk": "^3.0.3",
		"@noble/ciphers": "^2.2.0",
		"@noble/curves": "^2.2.0",
		"@noble/hashes": "^2.2.0",
		"@novasamatech/host-api": "^0.6.15",
		"@novasamatech/product-sdk": "^0.6.15",
		"@polkadot-api/descriptors": "file:.papi/descriptors",
		"@polkadot-labs/hdkd": "^0.0.26",
		"@polkadot-labs/hdkd-helpers": "^0.0.27",
		"@polkadot/util-crypto": "^13.5.9",
		"@privy-io/react-auth": "^3.22.1",
		"@zk-kit/lean-imt": "^2.2.4",
		"blakejs": "^1.2.1",
		"circomlib": "^2.0.5",
		"circomlibjs": "^0.1.7",
		"multiformats": "^13.4.2",
		"polkadot-api": "^1.23.3",
		"qrcode": "^1.5.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^7.12.0",
		"snarkjs": "^0.7.6",
		"viem": "^2.47.6",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@parity/host-api-test-sdk": "^0.7.0",
		"@playwright/test": "^1.59.1",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"circom2": "^0.2.22",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.0.1",
		"postcss": "^8.4.49",
		"prettier": "^3.8.1",
		"tailwindcss": "^3.4.15",
		"typescript": "~5.6.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^6.0.1",
		"vite-plugin-node-polyfills": "^0.26.0",
		"vitest": "^4.1.5"
	}
}
